# PhysioWave — Environment Configuration
# Copy this file to .env and fill in the values.

# Ollama (local AI server)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:4b
VISION_MODEL=moondream
EMBEDDING_MODEL=nomic-embed-text

# Security — Generate a strong key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
SECRET_KEY=

# Database
DATABASE_URL=sqlite:///./backend/data/physiowave.db
CHROMADB_PATH=./backend/data/chromadb

# Server
HOST=0.0.0.0
PORT=8000
